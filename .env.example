# ─────────────────────────────────────────────────────────
# SIMS Hospital HMS — Environment Variables Template
# ─────────────────────────────────────────────────────────
# STEP 1: Copy this file and rename it to .env
# STEP 2: Fill in your actual values below
# STEP 3: NEVER commit .env to GitHub — it contains your password!
#         The .gitignore file already blocks it.
# ─────────────────────────────────────────────────────────

# MongoDB Atlas connection string
# How to get it:
#   1. Go to cloud.mongodb.com
#   2. Click your Cluster → Connect → Drivers
#   3. Copy the connection string
#   4. Replace <password> with your DB user password
#   5. Change the database name to: sims_hms
MONGODB_URI=mongodb+srv://YOUR_DB_USER:YOUR_DB_PASSWORD@cluster0.xxxxx.mongodb.net/sims_hms?retryWrites=true&w=majority

# Server port — Render sets this automatically, keep 3000 for local dev
PORT=3000
